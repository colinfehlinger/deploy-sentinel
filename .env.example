# Application
NODE_ENV=development
PORT=3000

# AWS
AWS_REGION=us-east-1
DYNAMODB_TABLE=deploy-sentinel-deployments-dev
SQS_QUEUE_URL=http://localhost:9324/queue/deploy-events

# Secrets
WEBHOOK_SECRET=your-webhook-secret-min-16-chars

# Local dev overrides (used by docker-compose)
DYNAMODB_ENDPOINT=http://localhost:8000
SQS_ENDPOINT=http://localhost:9324
